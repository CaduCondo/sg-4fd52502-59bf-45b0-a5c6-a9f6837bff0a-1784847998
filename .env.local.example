# ============================================
# TEMPLATE DE VARIÁVEIS DE AMBIENTE
# ============================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.local na raiz do projeto
# 2. Preencha os valores reais do Supabase (nunca commite .env.local!)
# 3. O arquivo .env.local é ignorado pelo Git (.gitignore)
#
# ============================================

# Supabase - Obrigatórias para a aplicação funcionar
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-secreta-aqui

# URL do Site (opcional - padrão: http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# ONDE ENCONTRAR ESSAS CHAVES:
# ============================================
# 
# 1. Acesse: https://supabase.com/dashboard/project/SEU_PROJETO/settings/api
# 
# 2. NEXT_PUBLIC_SUPABASE_URL:
#    - Seção "Project URL"
#    - Exemplo: https://abcdefghijklmnop.supabase.co
# 
# 3. NEXT_PUBLIC_SUPABASE_ANON_KEY:
#    - Seção "Project API keys"
#    - Chave "anon" / "public"
#    - É segura para uso no cliente (pública)
# 
# 4. SUPABASE_SERVICE_ROLE_KEY:
#    - Seção "Project API keys"
#    - Chave "service_role"
#    - ⚠️ SECRETA - Nunca exponha no cliente!
#    - Usada apenas em servidor e testes E2E
# 
# ============================================